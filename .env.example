# Môi trường chạy hệ thống (development / production)
NODE_ENV="development"

# Khóa bí mật API kết nối trí tuệ nhân tạo Gemini
# AI Studio tự động nạp khóa này tại runtime từ panel cấu hình Secrets
GEMINI_API_KEY=""

# Cấu hình dự án Firebase (Server-side)
FIREBASE_PROJECT_ID=""
FIREBASE_DATABASE_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_SERVICE_ACCOUNT_JSON=""
FIREBASE_SERVICE_ACCOUNT_BASE64=""
GOOGLE_APPLICATION_CREDENTIALS=""
ALLOWED_EMAIL_DOMAINS=""
ALLOW_MOCK_AUTH=""
DEV_ROLE_MAPPINGS=""

# Cấu hình nguồn dữ liệu cho module tasks-query
TASKS_COLLECTION=""
TASKS_TIMESTAMP_MODE="firestore" # firestore | iso-string

# Đường dẫn máy chủ chạy ứng dụng (Local hoặc Cloud Run)
APP_URL="http://localhost:3000"

# Cấu hình Firebase Web SDK (Client-side)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_ALLOW_MOCK_AUTH=""

