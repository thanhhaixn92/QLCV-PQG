rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Core security: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Read-only safety rules for tasks collection (Client-side access restriction)
    match /tasks/{taskId} {
      // Strictly deny any client-side write operations
      allow write: if false;

      // Allow reads only for authenticated users with proper security clearance
      allow read: if request.auth != null 
        && (
          request.auth.token.role == "admin"
          || request.auth.token.role == "manager"
          || resource.data.creator.uid == request.auth.uid
          || resource.data.creatorUid == request.auth.uid
          || resource.data.assignee.uid == request.auth.uid
          || resource.data.assigneeUid == request.auth.uid
        );
    }
  }
}
